root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csproj}]
indent_size = 4
# Keep nullable + warnings honest; let `dotnet format` tidy whitespace/usings.
dotnet_diagnostic.CS8019.severity = warning

[*.py]
indent_size = 4
max_line_length = 100

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
